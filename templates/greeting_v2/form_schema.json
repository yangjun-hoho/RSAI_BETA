{
  "fields": [
    {
      "id": "event_title",
      "label": "행사명",
      "type": "text",
      "required": true,
      "placeholder": "예: 2026년 남양주시 시민의날"
    },
    {
      "id": "speech_type",
      "label": "말씀 유형",
      "type": "select",
      "options": ["인사말", "축사", "격려사", "환영사", "기념사"],
      "default": "인사말"
    },
    {
      "id": "audience",
      "label": "청중",
      "type": "text",
      "placeholder": "예: 시민 여러분, 관계자 여러분"
    },
    {
      "id": "core_content",
      "label": "핵심 내용",
      "type": "textarea",
      "placeholder": "행사 의미, 강조할 내용, 주요 성과 등을 자유롭게 입력하세요."
    },
    {
      "id": "speech_length",
      "label": "분량",
      "type": "select",
      "options": ["짧게 (1~2분)", "보통 (3~5분)", "길게 (5~7분)"],
      "default": "보통 (3~5분)"
    }
  ]
}
